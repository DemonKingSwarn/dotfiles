#!/bin/sh

printf "%s\n\t" "$1"
printf "extract?[y/N]"
read ans

choose() {
  local filename="$1"
  case $1 in
        *.tar.bz2) tar -xjf $filename ;;
        *.tar.gz) tar -xzf $filename ;;
        *.rar) unrar e $filename ;;
        *.gz) gunzip $filename ;;
        *.tar) tar -xf $filename ;;
        *.tbz2) tar -xjf $filename ;;
        *.tgz) tar -xzf $filename ;;
        *.zip) unzip $filename ;;
        *.Z) uncompress $filename ;;
        *.7z) 7zz x $filename ;;
        *.tar.xz) tar -xf $filename ;;
    esac
}


[ $ans = "y" ] && choose "$1"
