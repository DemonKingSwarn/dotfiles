@import "~/.cache/wal/colors-rofi-dark.rasi"

configuration {
    font: "SF Pro 14";
    lines: 10;
    fixed-num-lines: true;
}

entry {
    placeholder: "";
    padding: 8px 0 8px 8px;
}

inputbar {
    children: [entry];
}

mainbox {
    border: 2px;
    border-color: @border-color;
    border-radius: 10px;
    padding: 10px;
}

window {
    border-radius: 11px;
    border: 1px solid;
    border-color: @background;
    background-color: @background;
    padding: 0px;
    width: 30%;
}

listview {
    lines: 10;
}

element {
    padding: 10px;
    height: 50px;
    border-radius: 5px;
    children: [ element-text, element-icon ];
}

#scrollbar {
    handle-width: 4px;
    padding: 0;
}
